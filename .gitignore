# Виртуальное окружение
.venv/
venv/
env/
.env/
ENV/

# Python
__pycache__/
*.py[cod]
*.so
.Python
*.egg-info/
dist/
build/
*.egg

# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store
